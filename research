#!/usr/bin/env node
/**
 * Deep Research Agent — Interactive CLI
 * 
 * Usage:
 *   ./research "query kamu disini"
 *   ./research --interactive  (mode ngobrol)
 * 
 * Examples:
 *   ./research "harga ETH sekarang dan yield nya"
 *   ./research "apa itu sumopod.com"
 *   ./research --interactive
 */

const API = "http://localhost:3001";

async function main() {
  const args = process.argv.slice(2);
  
  if (args.length === 0 || args[0] === "--interactive" || args[0] === "-i") {
    await interactiveMode();
  } else {
    const query = args.join(" ");
    await singleQuery(query);
  }
}

async function singleQuery(query) {
  if (query.startsWith("deep:")) {
    const domain = query.replace("deep:", "").trim();
    console.log(`\n🔍 Deep research: ${domain}\n`);
    
    const start = Date.now();
    try {
      const resp = await fetch(`${API}/research/deep`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ domain }),
      });
      const data = await resp.json();
      const duration = ((Date.now() - start) / 1000).toFixed(1);
      
      if (data.error) {
        console.log(`❌ Error: ${data.error}`);
        return;
      }

      console.log("=".repeat(60));
      console.log("📝  DEEP RESEARCH RESULT");
      console.log("=".repeat(60));
      console.log(data.summary || "Tidak ada hasil");
      console.log();
      
      console.log("=".repeat(60));
      console.log(`📡  ${data.totalEndpointsFound} ENDPOINTS FOUND`);
      console.log("=".repeat(60));
      const endpoints = data.apiEndpoints || [];
      for (const ep of endpoints.slice(0, 10)) {
        const icon = ep.confidence >= 0.8 ? "🟢" : ep.confidence >= 0.6 ? "🟡" : "🟠";
        console.log(`  ${icon} [${ep.method}] ${ep.url.substring(0, 80)} (${ep.description || 'No description'})`);
      }
      if (endpoints.length > 10) {
        console.log(`  ... dan ${endpoints.length - 10} lainnya`);
      }

      if (data.credentials && data.credentials.length > 0) {
        console.log();
        console.log("=".repeat(60));
        console.log(`🔑  ${data.credentials.length} CREDENTIALS FOUND`);
        console.log("=".repeat(60));
        for (const cred of data.credentials) {
          console.log(`  🔑 [${cred.type}] ${cred.key}: ${cred.value.substring(0, 50)}... (Source: ${cred.source})`);
        }
      }

      console.log();
      console.log(`⚡ Selesai dalam ${duration}s`);
    } catch (err) {
      console.log(`❌ Gagal: ${err.message}`);
      console.log("Pastikan server udah jalan: cd deep-research-agent && npm run dev");
    }
  } else {
    console.log(`\n🔍 Researching: "${query}"\n`);
    
    const start = Date.now();
    
    try {
      const resp = await fetch(`${API}/research`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          query,
          maxDepth: 2,
          maxSources: 5,
          preferApi: true,
        }),
      });

      const data = await resp.json();
      const duration = ((Date.now() - start) / 1000).toFixed(1);
      
      if (data.error) {
        console.log(`❌ Error: ${data.error}`);
        return;
      }

      // Print summary
      console.log("=".repeat(60));
      console.log("📝  HASIL RESEARCH");
      console.log("=".repeat(60));
      console.log(data.summary?.substring(0, 2000) || "Tidak ada hasil");
      console.log();
      
      // Print findings
      const findings = data.findings || [];
      if (findings.length > 0) {
        console.log("=".repeat(60));
        console.log(`📊  ${findings.length} FINDINGS`);
        console.log("=".repeat(60));
        
        for (const f of findings.slice(0, 5)) {
          const icon = f.confidence >= 0.8 ? "🟢" : f.confidence >= 0.6 ? "🟡" : "🟠";
          const clean = f.claim.replace(/\n/g, " ").substring(0, 150);
          console.log(`  ${icon} [${(f.confidence * 100).toFixed(0)}%] ${clean}`);
        }
        if (findings.length > 5) {
          console.log(`  ... dan ${findings.length - 5} lainnya`);
        }
      }
      
      // Print sources
      const sources = data.citations || [];
      if (sources.length > 0) {
        console.log();
        console.log("=".repeat(60));
        console.log(`📚  ${sources.length} SUMBER`);
        console.log("=".repeat(60));
        for (const s of sources.slice(0, 5)) {
          console.log(`  [${s.index}] ${s.title?.substring(0, 80) || s.url.substring(0, 80)}`);
        }
      }
      
      console.log();
      console.log(`⚡ Selesai dalam ${duration}s`);
      
    } catch (err) {
      console.log(`❌ Gagal: ${err.message}`);
      console.log("Pastikan server udah jalan: cd deep-research-agent && npm run dev");
    }
  }
}

async function interactiveMode() {
  console.log("\n🧠  DEEP RESEARCH AGENT — Interactive Mode");
  console.log("  Ketik 'exit' atau 'quit' buat keluar");
  console.log("  Ketik 'deep:domain.com' buat pake layer 4 (bundle parser)");
  console.log("=".repeat(60));
  
  const readline = await import("readline");
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });
  
  const ask = () => {
    rl.question("\n❯ ", async (input) => {
      if (["exit", "quit", "q"].includes(input.toLowerCase())) {
        console.log("👋 Bye!");
        rl.close();
        return;
      }
      
      if (input.startsWith("deep:")) {
        const domain = input.replace("deep:", "").trim();
        console.log(`\n🔍 Deep research: ${domain}`);
        try {
          const resp = await fetch(`${API}/research/deep`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ domain }),
          });
          const data = await resp.json();
          console.log(`  Ditemukan ${data.totalEndpointsFound} endpoint, ${data.totalEndpointsQueried} berhasil ditembak`);
          if (data.credentials?.length) {
            console.log(`  🔑 ${data.credentials.length} kredensial ditemukan`);
          }
          const endpoints = data.apiEndpoints || [];
          for (const ep of endpoints.slice(0, 5)) {
            console.log(`  📡 ${ep.method} ${ep.url.substring(0, 80)}`);
          }
        } catch (err) {
          console.log(`❌ Error: ${err.message}`);
        }
      } else {
        await singleQuery(input);
      }
      
      ask();
    });
  };
  
  ask();
}

main().catch(console.error);
