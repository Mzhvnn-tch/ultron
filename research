#!/usr/bin/env node
/**
 * Deep Research Agent - CLI
 *
 * Usage:
 *   ./research "query here"
 *   ./research --interactive
 *
 * Examples:
 *   ./research "harga ETH sekarang"
 *   ./research "apa itu sumopod.com"
 *   ./research "deep:uniswap.org"
 *   ./research --interactive
 */

const API = "http://localhost:3001";

const divider = () => console.log("-".repeat(60));

async function main() {
  const args = process.argv.slice(2);

  if (args.length === 0 || args[0] === "--interactive" || args[0] === "-i") {
    await interactiveMode();
  } else {
    const query = args.join(" ");
    await singleQuery(query);
  }
}

async function singleQuery(query) {
  if (query.startsWith("deep:")) {
    const domain = query.replace("deep:", "").trim();
    console.log(`\nDeep research: ${domain}\n`);

    const start = Date.now();
    try {
      const resp = await fetch(`${API}/research/deep`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ domain }),
      });
      const data = await resp.json();
      const duration = ((Date.now() - start) / 1000).toFixed(1);

      if (data.error) {
        console.log(`Error: ${data.error}`);
        return;
      }

      divider();
      console.log("DEEP RESEARCH RESULT");
      divider();
      console.log(data.summary || "No results");
      console.log();

      divider();
      console.log(`ENDPOINTS FOUND: ${data.totalEndpointsFound}`);
      divider();
      const endpoints = data.apiEndpoints || [];
      for (const ep of endpoints.slice(0, 10)) {
        const conf = `${(ep.confidence * 100).toFixed(0)}%`;
        console.log(`  [${ep.method}] [${conf}] ${ep.url.substring(0, 75)}`);
        if (ep.description) console.log(`         ${ep.description}`);
      }
      if (endpoints.length > 10) {
        console.log(`  ... and ${endpoints.length - 10} more`);
      }

      if (data.credentials && data.credentials.length > 0) {
        console.log();
        divider();
        console.log(`CREDENTIALS FOUND: ${data.credentials.length}`);
        divider();
        for (const cred of data.credentials) {
          console.log(`  [${cred.type}] ${cred.key}: ${cred.value.substring(0, 50)}... (source: ${cred.source})`);
        }
      }

      console.log();
      console.log(`Done in ${duration}s`);
    } catch (err) {
      console.log(`Error: ${err.message}`);
      console.log("Make sure the server is running: npm run dev");
    }

  } else {
    console.log(`\nResearching: "${query}"\n`);

    const start = Date.now();
    try {
      const resp = await fetch(`${API}/research`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          query,
          maxDepth: 2,
          maxSources: 5,
          preferApi: true,
        }),
      });

      const data = await resp.json();
      const duration = ((Date.now() - start) / 1000).toFixed(1);

      if (data.error) {
        console.log(`Error: ${data.error}`);
        return;
      }

      divider();
      console.log("RESULT");
      divider();
      console.log(data.summary?.substring(0, 2000) || "No results");
      console.log();

      const findings = data.findings || [];
      if (findings.length > 0) {
        divider();
        console.log(`FINDINGS (${findings.length})`);
        divider();
        for (const f of findings.slice(0, 5)) {
          const conf = `${(f.confidence * 100).toFixed(0)}%`;
          const clean = f.claim.replace(/\n/g, " ").substring(0, 150);
          console.log(`  [${conf}] ${clean}`);
        }
        if (findings.length > 5) {
          console.log(`  ... and ${findings.length - 5} more`);
        }
      }

      const sources = data.citations || [];
      if (sources.length > 0) {
        console.log();
        divider();
        console.log(`SOURCES (${sources.length})`);
        divider();
        for (const s of sources.slice(0, 5)) {
          console.log(`  [${s.index}] ${s.title?.substring(0, 80) || s.url.substring(0, 80)}`);
        }
      }

      console.log();
      console.log(`Done in ${duration}s`);

    } catch (err) {
      console.log(`Error: ${err.message}`);
      console.log("Make sure the server is running: npm run dev");
    }
  }
}

async function interactiveMode() {
  console.log("\nDeep Research Agent - Interactive Mode");
  console.log("  Type 'exit' or 'quit' to stop");
  console.log("  Type 'deep:domain.com' to use the JS bundle parser (Layer 4)");
  divider();

  const readline = await import("readline");
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  const ask = () => {
    rl.question("\n> ", async (input) => {
      input = input.trim();

      if (["exit", "quit", "q"].includes(input.toLowerCase())) {
        console.log("Bye.");
        rl.close();
        return;
      }

      if (input.startsWith("deep:")) {
        const domain = input.replace("deep:", "").trim();
        console.log(`\nDeep research: ${domain}`);
        try {
          const resp = await fetch(`${API}/research/deep`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ domain }),
          });
          const data = await resp.json();
          console.log(`  Endpoints found   : ${data.totalEndpointsFound}`);
          console.log(`  Endpoints queried : ${data.totalEndpointsQueried}`);
          if (data.credentials?.length) {
            console.log(`  Credentials found : ${data.credentials.length}`);
          }
          const endpoints = data.apiEndpoints || [];
          for (const ep of endpoints.slice(0, 5)) {
            console.log(`  [${ep.method}] ${ep.url.substring(0, 80)}`);
          }
        } catch (err) {
          console.log(`Error: ${err.message}`);
        }
      } else {
        await singleQuery(input);
      }

      ask();
    });
  };

  ask();
}

main().catch(console.error);
