# Deep Research Agent Configuration

# Server
PORT=3002
HOST=0.0.0.0

# LLM (for query decomposition & synthesis)
# Use any OpenAI-compatible API
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Browser (Playwright)
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
STEALTH_MODE=true

# Cache
CACHE_DB_PATH=./data/endpoints.db
CACHE_TTL_HOURS=720

# Rate Limiting
MAX_CONCURRENT_DOMAINS=5
REQUEST_DELAY_MS=500

# CROO CAP Protocol (agent-to-agent marketplace on Base)
# Get your SDK key from https://dashboard.croo.network
CROO_ENABLED=false
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...
